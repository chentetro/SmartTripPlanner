<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ui.details.TripDetailsFragment">

    <LinearLayout
        android:id="@+id/tripDetailsHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#1E73E8"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDetailTripName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                tools:text="Weekend in Tel Aviv" />

            <ImageButton
                android:id="@+id/btnEditTripSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="@string/edit_trip_details"
                android:padding="12dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_settings"
                app:tint="#FFFFFF" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDetailTripDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#D9FFFFFF"
            android:textSize="15sp"
            tools:text="Friday, June 18, 2026" />

        <TextView
            android:id="@+id/tvDetailTripTimeRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            tools:text="09:00 - 18:00" />

        <TextView
            android:id="@+id/tvDetailTripMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#D9FFFFFF"
            android:textSize="14sp"
            tools:text="Vibe: museums, cultural • 2 participants • 5 km radius" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddToFavorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/add_to_favorites"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1E73E8"
            app:cornerRadius="0dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp" />



    </LinearLayout>

    <TextView
        android:id="@+id/tvTripSitesTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:text="@string/trip_sites"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tripDetailsHeader" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTripSites"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTripSitesTitle"
        tools:listitem="@layout/item_site" />

</androidx.constraintlayout.widget.ConstraintLayout>
